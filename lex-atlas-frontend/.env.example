# ───────────────────────────────────────────────────────────────────────────
# Lex Atlas configuration · copy to .env (never commit)
# ───────────────────────────────────────────────────────────────────────────

# --- Neo4j (graph store) -----------------------------------------------------
# Local dev: docker-compose.yml exposes Bolt on localhost:7687
# Production: Modal/Aura URI
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# --- Ollama (local LLM + embeddings) ----------------------------------------
# Local dev: native install; production: Modal web_server URL
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_DRAFTER=gemma3:27b
OLLAMA_MODEL_WORKER=gemma3:4b
OLLAMA_MODEL_EMBED=bge-m3
OLLAMA_MODEL_RERANKER=bge-reranker-v2-m3

# --- DSPy agent sidecar ------------------------------------------------------
# The Python FastAPI server that runs the actual agent loop.
# Next.js rewrites /agent/* to here.
AGENT_SIDECAR_URL=http://localhost:8000

# --- Semantic Finlex (CRAG fallback ground truth) ---------------------------
SPARQL_FINLEX_ENDPOINT=https://data.finlex.fi/sparql

# --- CELLAR / EUR-Lex (EU bridge — the out-of-scope flex) -------------------
SPARQL_CELLAR_ENDPOINT=https://publications.europa.eu/webapi/rdf/sparql

# --- Cost meter --------------------------------------------------------------
SHOW_COST_METER=true
COST_KWH_PRICE_EUR=0.15

# --- Hosted fallback (optional — only if local melts mid-demo) --------------
ANTHROPIC_API_KEY=

# --- Vercel deployment -------------------------------------------------------
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_APP_URL=http://localhost:3000
